{
  "name": "@mitchallen/grid",
  "version": "0.1.25",
  "description": "A 2D grid that uses zero-based indexing",
  "main": "src/index.js",
  "browser": "dist/grid.min.js",
  "scripts": {
    "start": "node src/index.js",
    "build": "node build.js",
    "lint": "eslint src/",
    "test": "node build.js && mocha --recursive --timeout 20000",
    "watch": "node build.js --watch",
    "test-square": "mocha --recursive test/square/ --timeout 5000",
    "test-circle": "mocha --recursive test/circle/ --timeout 5000",
    "test-hexagon": "mocha --recursive test/hexagon/ --timeout 5000",
    "test-triangle": "mocha --recursive test/triangle/ --timeout 5000",
    "test-create": "mocha --recursive test/create/ --timeout 5000",
    "test-debug": "mocha -g '@DEBUG' --recursive --timeout 20000",
    "test-jenkins": "mocha --recursive --timeout 20000 -R xunit test/ > test-reports.xml",
    "pubinit": "node build.js && npm publish --access public",
    "publish-pkg": "node build.js && npm version patch && git push --follow-tags && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mitchallen/grid.git"
  },
  "author": "Mitch Allen <npm@mitchallen.com> (http://mitchallen.com)",
  "license": "ISC",
  "devDependencies": {
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "mocha": "^11.7.5",
    "should": "^10.0.0",
    "supertest": "^7.1.1"
  },
  "dependencies": {
    "@mitchallen/grid-core": "^0.1.10",
    "@mitchallen/grid-square": "^0.1.9"
  }
}
